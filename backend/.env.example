# Environment variables for e-commerce backend

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/ecommerce_db"

# JWT Configuration (legacy - kept for reference)
# JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Auth (Better Auth) - REQUIRED in production
BETTER_AUTH_SECRET="generate-a-strong-secret-with-openssl-rand-base64-32"

# Server
PORT=3001
NODE_ENV="development"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Mock Email (for development - logs to console)
MOCK_EMAIL="true"

# Email (Resend) - Get your API key from https://resend.com
RESEND_API_KEY=""
STORE_NAME="My Store"
FROM_EMAIL="noreply@resend.dev"
